{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FinalSub",
  "version": "1.0.10",
  "identifier": "com.gravitypoet.finalsub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FinalSub",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "connect-src": ["ipc:", "http://ipc.localhost"],
        "img-src": ["'self'", "asset:", "http://asset.localhost", "data:", "blob:"],
        "style-src": ["'self'", "'unsafe-inline'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/whisper-cli"
    ],
    "resources": [
      "licenses/ffmpeg-GPLv2.txt",
      "licenses/ffmpeg-NOTICE.md",
      "resources/parakeet/parakeet_transcribe.py",
      "licenses/whisper.cpp-LICENSE.txt",
      "licenses/whisper-NOTICE.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
