{
  "name": "finalsubtauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "sign:local": "codesign --force --deep --sign - \"src-tauri/target/release/bundle/macos/FinalSub Tauri Preview.app\"",
    "verify:bundle": "codesign --verify --deep --strict --verbose=4 \"src-tauri/target/release/bundle/macos/FinalSub Tauri Preview.app\"",
    "build:local": "npm run tauri:build && npm run sign:local && npm run verify:bundle"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react-router-dom": "^7.6.1",
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2",
    "tailwindcss": "^4.1.7",
    "@tailwindcss/vite": "^4.1.7"
  }
}
